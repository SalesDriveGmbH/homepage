# =============================================================================
# SalesDrive Beta · app.lehnerconsulting.com
# .htaccess für All-Inkl (Apache 2.4)
# =============================================================================

# -----------------------------------------------------------------------------
# HTTPS erzwingen
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http → https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # www → non-www (falls Subdomain mal mit www angesteuert wird)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # Clean URLs: /impressum → /impressum.html (intern), .html in URL entfernen
  # 1) Wenn URL .html enthält, redirect auf saubere URL
  RewriteCond %{THE_REQUEST} \s/([^?]*?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # 2) Intern: ohne .html → mit .html servieren
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# -----------------------------------------------------------------------------
# Default-Dokument
# -----------------------------------------------------------------------------
DirectoryIndex index.html

# -----------------------------------------------------------------------------
# Security Header
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# -----------------------------------------------------------------------------
# Gzip-Kompression (deutlich schnellere Ladezeit)
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE font/otf
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# -----------------------------------------------------------------------------
# Browser-Caching für statische Assets (1 Jahr)
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML nur kurz cachen (für Updates)
  ExpiresByType text/html "access plus 1 hour"

  # Bilder / Fonts / CSS / JS lang cachen
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# -----------------------------------------------------------------------------
# Cache-Control Header zusätzlich für /assets/
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|woff|woff2|ttf|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# -----------------------------------------------------------------------------
# Korrekte MIME-Types für moderne Formate
# -----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType font/woff .woff
</IfModule>

# -----------------------------------------------------------------------------
# Versteckte Dateien blocken
# -----------------------------------------------------------------------------
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# vercel.json blocken (gehört nicht ins Web)
<FilesMatch "(vercel\.json|README\.md|\.DS_Store)">
  Require all denied
</FilesMatch>
